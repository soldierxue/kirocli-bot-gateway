# =============================================================================
# Feishu (Lark)
# =============================================================================

FEISHU_ENABLED=true
FEISHU_APP_ID=                         # ← Required: Feishu App ID (cli_xxx)
FEISHU_APP_SECRET=                     # ← Required: Feishu App Secret
FEISHU_BOT_NAME=                       # ← Required: Bot display name in Feishu

# =============================================================================
# Discord
# =============================================================================

DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=                     # ← Required: Discord Bot Token
DISCORD_GUILD_ID=                      # ← Required: Server ID, comma-separated for multiple (right-click server → Copy ID)
DISCORD_ADMIN_USER_ID=                 # Allowed user IDs, comma-separated. Leave empty to allow anyone who @mentions
DISCORD_REQUIRE_MENTION=true           # Whether @mention is required in guild channels (true/false)
DISCORD_SLASH_COMMANDS=true            # Enable /help /agent /model slash commands

# For fine-grained control, create discord_policy.json (see discord_policy.example.json)

# =============================================================================
# Kiro CLI
# =============================================================================

KIRO_PATH=kiro-cli                     # Path to kiro-cli executable
# KIRO_DEFAULT_MODEL=claude-opus-4.6   # Default model for new sessions (default: claude-opus-4.6)
KIRO_CWD=/tmp/kirocli-bot-gateway  # Working directory
KIRO_IDLE_TIMEOUT=300                  # Auto-stop kiro-cli after N seconds of inactivity (0 = disabled)
# KIRO_AUTO_APPROVE=true               # Auto-approve all Kiro tool requests, trust mode (default: true)
# KIRO_FALLBACK_MODEL=claude-sonnet-4.6  # Auto-switch on rate limit or model unavailable (default: none)
# KIRO_MAX_INSTANCES=10                # Max concurrent kiro-cli instances per gateway (default: 10, LRU eviction)
# KIRO_COLD_START_LIMIT=4             # Max concurrent kiro-cli cold starts (default: 4)
# KIRO_GATEWAY_STATE_DIR=~/.kirocli-gateway  # Persistent state dir for session map, memory, logs (default: ~/.kirocli-gateway)

# =============================================================================
# Heartbeat (periodic background check-in)
# =============================================================================
# HEARTBEAT_ENABLED=false              # Enable periodic heartbeat (default: false)
# HEARTBEAT_INTERVAL=900               # Heartbeat interval in seconds (default: 900 = 15 min)
# HEARTBEAT_TARGET=feishu:oc_xxx       # Target chat for heartbeat messages (platform:chat_id)
# HEARTBEAT_EXCLUDE=23:00-07:00/1-5   # Quiet hours: time range / weekday range (1=Mon, 7=Sun)

# =============================================================================
# Workspace Mode
# =============================================================================
# per_chat → Isolated subdirectory per chat, MCP/Skills from global ~/.kiro/ config (recommended for multi-user)
# fixed   → All chats share one directory, MCP/Skills from project-level {KIRO_CWD}/.kiro/ config (recommended for team projects)

KIRO_WORKSPACE_MODE=per_chat

# Per-platform override (optional, most users don't need this, see README)
# FEISHU_WORKSPACE_MODE=
# FEISHU_KIRO_CWD=
# DISCORD_WORKSPACE_MODE=
# DISCORD_KIRO_CWD=

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=INFO                         # DEBUG / INFO / WARNING / ERROR

# =============================================================================
# Message Handling
# =============================================================================
# Debounce: wait for quiet before processing (merges rapid messages into one)
# DEBOUNCE_DISCORD=1.5                 # Discord debounce window in seconds (default: 1.5)
# DEBOUNCE_FEISHU=1.0                  # Feishu debounce window in seconds (default: 1.0)
# DEBOUNCE_DEFAULT=1.5                 # Fallback for other platforms (default: 1.5)
# PENDING_CAP=20                       # Max pending messages per chat (default: 20)
